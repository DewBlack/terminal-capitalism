# Copia este archivo a:
#   .local/itch_deploy.env
#
# y ajusta valores.

# Modo de despliegue:
#   offline -> solo exporta y genera zip local (sin subir)
#   upload  -> exporta y sube a itch.io con butler
ITCH_DEPLOY_MODE=offline

# Destino remoto obligatorio (formato usuario/juego)
# Solo se usa si ITCH_DEPLOY_MODE=upload
ITCH_TARGET=tuusuario/terminal-capitalism

# Canal itch.io para HTML5
# Solo se usa si ITCH_DEPLOY_MODE=upload
ITCH_CHANNEL=web

# Opcional: release o debug
EXPORT_MODE=release

# Opcional: ruta del html exportado
WEB_EXPORT_PATH=Builds/Web/index.html

# Opcional: salida del paquete local
# ITCH_OUT_DIR=Builds/Itch/web
# ITCH_ZIP_NAME=terminal-capitalism-web-itch.zip
# SKIP_EXPORT=1  # empaqueta un export existente sin volver a exportar

# Opcional: version visible en itch (ej: 0.5.0)
# Solo se usa si ITCH_DEPLOY_MODE=upload
# ITCH_VERSION=0.1.0

# Opcional: 1 para evitar recompilar/reempaquetar y subir directo paquete existente
# SKIP_BUILD=0

# Opcional: ruta del paquete para butler
# Solo se usa si ITCH_DEPLOY_MODE=upload
# ITCH_PACKAGE_DIR=Builds/Itch/web/package
